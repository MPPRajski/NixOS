      "autoShowDelay": 150,
      "showOnWorkspaceSwitch": true,
      "widgets": {
        "left": [
          { "id": "Launcher" },
          { "id": "Clock" },
          { "id": "ActiveWindow" }
        ],
        "center": [
          {
            "id": "Workspace",
            "hideUnoccupied": false,
            "labelMode": "none"
          }
